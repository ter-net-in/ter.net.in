---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WordplayHeader from '@/components/WordplayHeader.astro';
import LogoAnimation from '@/components/LogoAnimation.astro';
---

<BaseLayout>
  <main>

    <WordplayHeader />

    <!-- ── Center: nav links ── -->
    <div class="nav-anchor">
    <div class="nav-cta" id="nav-cta">
      <a href="/blog" id="blog-link" class="nav-link">
        <span class="label">blog</span>
        <svg id="arrow-blog" class="arrow" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line x1="4" y1="20" x2="20" y2="4" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
          <polyline points="9,4 20,4 20,15" stroke="currentColor" stroke-width="3.5" stroke-linecap="square" stroke-linejoin="miter" stroke-miterlimit="10" fill="none"/>
        </svg>
      </a>
      <a href="/experiments" id="experiments-link" class="nav-link">
        <span class="label">experiments</span>
        <svg id="arrow-experiments" class="arrow" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line x1="4" y1="20" x2="20" y2="4" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
          <polyline points="9,4 20,4 20,15" stroke="currentColor" stroke-width="3.5" stroke-linecap="square" stroke-linejoin="miter" stroke-miterlimit="10" fill="none"/>
        </svg>
      </a>
    </div>
    </div>

    <!-- ── Grid overlay ── -->
    <div class="grid-overlay" aria-hidden="true">
      {Array.from({ length: 5 * 5 }).map((_, i) => <div class="grid-cell" />)}
    </div>

    <!-- ── Bottom-right: rotating logo ── -->
    <div class="logo-corner">
      <LogoAnimation instanceId="home" />
    </div>

  </main>
</BaseLayout>

<script>
  import { animate } from 'motion';

  animate(
    '#nav-cta',
    { opacity: [0, 1], y: [12, 0] },
    { duration: 0.8, delay: 0.6, easing: [0.16, 1, 0.3, 1] }
  );

  for (const { linkId, arrowId } of [
    { linkId: 'blog-link', arrowId: 'arrow-blog' },
    { linkId: 'experiments-link', arrowId: 'arrow-experiments' },
  ]) {
    const link  = document.getElementById(linkId)  as HTMLElement;
    const arrow = document.getElementById(arrowId) as HTMLElement;
    link.addEventListener('mouseenter', () => animate(arrow, { x: 4, y: -4 }, { duration: 0.2, easing: 'ease-out' }));
    link.addEventListener('mouseleave', () => animate(arrow, { x: 0, y: 0  }, { duration: 0.2, easing: 'ease-out' }));
  }
</script>

<style>
  main {
    height: 100svh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: clamp(2rem, 5vw, 3.5rem);
    position: relative;
  }

  .nav-anchor {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .nav-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.01em;
    color: #0047ff;
    text-transform: uppercase;
  }

  .arrow {
    display: block;
    width: 1em;
    height: 1em;
    color: #0047ff;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .grid-overlay {
      position: absolute;
      inset: 0;
      display: grid;
      grid-template-columns: clamp(2rem, 5vw, 3.5rem) 1fr 1fr 1fr clamp(2rem, 5vw, 3.5rem);
      grid-template-rows: clamp(2rem, 5vw, 3.5rem) 1fr 1fr 1fr clamp(2rem, 5vw, 3.5rem);
      pointer-events: none;
      z-index: 0;
    }

    .grid-cell {
      border-right: 1px solid rgba(0,0,0,0.04);
      border-bottom: 1px solid rgba(0,0,0,0.04);
    }

    /* No border on last column or last row */
    .grid-cell:nth-child(5n)   { border-right: none; }
    .grid-cell:nth-child(n+21) { border-bottom: none; }

    /* Content boundary — right edge of gutter col & left edge of gutter col */
    .grid-cell:nth-child(5n+1) { border-right-color: rgba(0,0,0,0.10); }
    .grid-cell:nth-child(5n+4) { border-right-color: rgba(0,0,0,0.10); }

    /* Content boundary — bottom edge of top gutter & top edge of bottom gutter */
    .grid-cell:nth-child(-n+5)           { border-bottom-color: rgba(0,0,0,0.10); }
    .grid-cell:nth-child(n+16):nth-child(-n+20) { border-bottom-color: rgba(0,0,0,0.10); }
  }

  .logo-corner {
    position: fixed;
    bottom: clamp(2rem, 5vw, 3.5rem);
    right: clamp(2rem, 5vw, 3.5rem);
    width: clamp(90px, 11vw, 148px);
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .logo-corner {
      width: 76px;
    }
  }
</style>
