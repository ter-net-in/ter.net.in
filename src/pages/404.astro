---
import LogoAnimation from "@/components/LogoAnimation.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found" description="This page does not exist.">
  <main>
    <img src="/404-sun.gif" alt="" class="sun" aria-hidden="true" />

    <div class="content">
      <h1>404</h1>
      <p>Whatever you were looking for,<br />it's not here. And honestly? Neither am I.</p>
      <a href="/">take me somewhere real</a>
    </div>

    <div class="logo-corner">
      <LogoAnimation instanceId="404" />
    </div>
  </main>
</BaseLayout>

<script>
  import { animate } from 'motion';

  animate(
    'h1',
    { x: [0, -8, 8, -6, 6, -3, 3, 0] },
    { duration: 1.6, easing: 'ease-in-out', repeat: Infinity, repeatDelay: 3 }
  );
</script>

<style>
  main {
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: clamp(2rem, 5vw, 3.5rem);
    position: relative;
    overflow: hidden;
  }

  .sun {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    margin: auto 0;
    height: 80%;
    width: auto;
    z-index: -1;
    clip-path: inset(12%);
    mix-blend-mode: multiply;
    pointer-events: none;
    animation: rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .content {
    width: 50%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    animation: rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  h1 {
    font-size: clamp(5rem, 12vw, 9rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  p {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--gray);
  }

  a {
    margin-top: 0.5rem;
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: #0047ff;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    main {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1rem;
    }

    .sun {
      position: static;
      height: auto;
      width: 70vw;
      margin: 0;
      clip-path: inset(12%);
    }

    .content {
      width: 100%;
      align-items: center;
      text-align: center;
    }

    h1 {
      font-size: clamp(4rem, 20vw, 6rem);
    }
  }

  .logo-corner {
    position: fixed;
    bottom: clamp(1.5rem, 3vw, 2.5rem);
    right: clamp(1.5rem, 3vw, 2.5rem);
    width: clamp(90px, 11vw, 148px);
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .logo-corner {
      width: 76px;
    }
  }
</style>
