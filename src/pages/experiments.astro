---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const experiments = (await getCollection("experiments")).sort(
	(a, b) => b.data.order - a.data.order,
);

const tags = Array.from(
	new Set(experiments.flatMap((experiment) => experiment.data.tags)),
).sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Experiments" description="Small things we built because we felt like it.">
  <div class="page-wrap">
    <header id="experiments-header">
      <a class="back" href="/">← ter.net.in</a>
      <h1>experiments</h1>
      <p class="sub">Things we built because we felt like it.</p>
    </header>

    <div class="filters" id="experiment-filters" aria-label="Filter experiments">
      <button class="filter-button is-active" type="button" data-filter="all">all</button>
      {tags.map((tag) => (
        <button class="filter-button" type="button" data-filter={tag}>{tag}</button>
      ))}
    </div>

    <ul id="experiments-list">
      {experiments.map((exp) => (
        <li data-tags={exp.data.tags.join(",")}>
          <a href={exp.data.url} target="_blank" rel="noopener noreferrer">
            <img src={exp.data.image} alt={exp.data.name} class="experiment-img" />
            <div class="experiment-meta">
              <span class="experiment-name">{exp.data.name}</span>
              <span class="experiment-desc">{exp.data.description}</span>
              <span class="experiment-tags" aria-label="Tags">
                {exp.data.tags.map((tag) => <span>{tag}</span>)}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<script>
  import { animate, stagger } from 'motion';

  animate(
    '#experiments-header',
    { opacity: [0, 1], y: [20, 0] },
    { duration: 0.8, easing: [0.16, 1, 0.3, 1] }
  );

  animate(
    '#experiments-list li',
    { opacity: [0, 1], y: [12, 0] },
    { duration: 0.7, delay: stagger(0.08, { start: 0.2 }), easing: [0.16, 1, 0.3, 1] }
  );

  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-button'));
  const experimentItems = Array.from(document.querySelectorAll<HTMLElement>('#experiments-list li'));

  for (const button of filterButtons) {
    button.addEventListener('click', () => {
      const filter = button.dataset.filter ?? 'all';

      for (const filterButton of filterButtons) {
        filterButton.classList.toggle('is-active', filterButton === button);
      }

      for (const item of experimentItems) {
        const tags = (item.dataset.tags ?? '').split(',').filter(Boolean);
        const visible = filter === 'all' || tags.includes(filter);
        item.hidden = !visible;
        item.style.opacity = visible ? '1' : '0';
      }
    });
  }
</script>

<style>
  .page-wrap {
    max-width: 620px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) var(--gap);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  header {
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--gray);
  }

  .back:hover {
    color: var(--black);
    text-decoration: none;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .sub {
    font-size: 0.9rem;
    color: var(--gray);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: -1.25rem;
  }

  .filter-button {
    appearance: none;
    border: 1px solid #e0e0e0;
    background: #fff;
    color: var(--gray);
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
		font: inherit;
		font-size: 0.78rem;
		line-height: 1;
		cursor: none;
	}

  .filter-button:hover,
  .filter-button.is-active {
    border-color: #0047ff;
    color: #0047ff;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  li {
    opacity: 0;
  }

  li[hidden] {
    display: none;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid #e8e8e8;
    color: inherit;
    text-decoration: none;
  }

  li:first-child a {
    border-top: 1px solid #e8e8e8;
  }

  li a:hover .experiment-name {
    text-decoration: underline;
  }

  .experiment-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
    mix-blend-mode: multiply;
  }

  .experiment-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .experiment-name {
    font-size: 1rem;
    font-weight: 700;
    color: #0047ff;
  }

  .experiment-desc {
    font-size: 0.82rem;
    color: var(--gray);
  }

	.experiment-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		pointer-events: none;
	}

  .experiment-tags span {
    width: fit-content;
    border: 1px solid #e6e6e6;
    border-radius: 999px;
    padding: 0.18rem 0.45rem;
    color: var(--gray);
    font-size: 0.7rem;
    line-height: 1;
  }
</style>
