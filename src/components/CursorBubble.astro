<div id="cursor-bubble">
  <svg id="cursor-ring" viewBox="0 0 44 44" aria-hidden="true">
    <circle cx="22" cy="22" r="20" />
  </svg>
</div>

<script>
  import { animate } from 'motion';

  const bubble = document.getElementById('cursor-bubble') as HTMLElement;

  const STORAGE_KEY = 'cursor-pos';

  const loadPosition = (): { x: number; y: number } | null => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  };

  const savePosition = (x: number, y: number): void => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ x, y }));
    } catch {
      // storage unavailable — fail silently
    }
  };

  const isTouchDevice = () => window.matchMedia('(pointer: coarse)').matches;
  if (isTouchDevice()) {
    bubble.style.display = 'none';
  } else {
    const saved = loadPosition();
    let mouseX = saved?.x ?? -100;
    let mouseY = saved?.y ?? -100;
    let bubbleX = saved?.x ?? -100;
    let bubbleY = saved?.y ?? -100;
    let prevBubbleX = bubbleX;
    let prevBubbleY = bubbleY;
    let stretch = 1;
    let rafId: number;
    let isLightboxOpen = false;

    type CursorState = 'default' | 'link' | 'image' | 'close';
    let currentState: CursorState = 'default';

    const lerp = (a: number, b: number, t: number): number => a + (b - a) * t;
    const clamp = (v: number, min: number, max: number): number => Math.min(Math.max(v, min), max);

    function loop(): void {
      prevBubbleX = bubbleX;
      prevBubbleY = bubbleY;
      bubbleX = lerp(bubbleX, mouseX, 0.12);
      bubbleY = lerp(bubbleY, mouseY, 0.12);

      const dx = bubbleX - prevBubbleX;
      const dy = bubbleY - prevBubbleY;
      const speed = Math.sqrt(dx * dx + dy * dy);

      const targetStretch = clamp(1 + speed * 0.06, 1, 1.6);
      stretch = lerp(stretch, targetStretch, 0.2);

      const angle = speed > 0.5 ? Math.atan2(dy, dx) * (180 / Math.PI) : 0;
      const scaleX = stretch;
      const scaleY = clamp(1 / stretch, 0.4, 1);

      bubble.style.transform = `translate(calc(${bubbleX}px - 50%), calc(${bubbleY}px - 50%)) rotate(${angle}deg) scale(${scaleX}, ${scaleY})`;

      rafId = requestAnimationFrame(loop);
    }

    loop();

    document.addEventListener('mousemove', (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      savePosition(mouseX, mouseY);
    });

    document.addEventListener('mouseleave', () => {
      bubble.style.opacity = '0';
    });

    document.addEventListener('mouseenter', () => {
      bubble.style.opacity = '1';
    });

    const STATES: Record<CursorState, Record<string, string>> = {
      default: { width: '12px', height: '12px', background: 'rgba(0,0,0,0.7)',      border: '1.5px solid transparent' },
      link:    { width: '48px', height: '48px', background: 'rgba(0,71,255,0.12)',   border: '1.5px solid rgba(0,71,255,0.5)' },
      image:   { width: '40px', height: '40px', background: 'rgba(0,0,0,0.0)',       border: '1.5px solid transparent' },
      close:   { width: '40px', height: '40px', background: 'rgba(255,255,255,0.1)', border: '1.5px solid rgba(255,255,255,0.45)' },
    };

    function setState(next: CursorState): void {
      if (next === currentState) return;
      currentState = next;
      bubble.classList.toggle('is-image', next === 'image');
      animate(bubble, STATES[next], { duration: 0.25, easing: [0.16, 1, 0.3, 1] });
    }

    document.addEventListener('lightbox:open', () => {
      isLightboxOpen = true;
      const dialog = document.getElementById('lightbox');
      if (dialog) dialog.appendChild(bubble);
    });

    document.addEventListener('lightbox:close', () => {
      isLightboxOpen = false;
      setState('default');
      document.body.appendChild(bubble);
    });

    document.addEventListener('mouseover', (e: MouseEvent) => {
      const target = e.target as Element;
      const isZoomable = !!target.closest('[data-zoomable]');
      const isInteractive = !!target.closest('a, button, [role="button"]');
      const isBackdrop = isLightboxOpen && e.target === document.getElementById('lightbox');

      if (isZoomable && !isLightboxOpen) setState('image');
      else if (isBackdrop) setState('close');
      else if (isInteractive) setState('link');
      else setState(isLightboxOpen ? 'close' : 'default');
    });
  }
</script>

<style>
  #cursor-bubble {
    display: none;
  }

  @media (pointer: fine) {
    #cursor-bubble {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 12px;
      height: 12px;
      background: rgba(0, 0, 0, 0.7);
      border: 1.5px solid transparent;
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      will-change: transform;
      transition: opacity 0.2s;
    }

    #cursor-ring {
      position: absolute;
      inset: -2px;
      width: calc(100% + 4px);
      height: calc(100% + 4px);
      overflow: visible;
      opacity: 0;
      transition: opacity 0.25s;
      pointer-events: none;
    }

    #cursor-ring circle {
      fill: none;
      stroke: transparent;
      stroke-width: 1.5;
      stroke-dasharray: 3 11;
      stroke-linecap: round;
    }

    #cursor-bubble.is-image #cursor-ring {
      opacity: 1;
      animation: ring-spin 7s linear infinite;
    }

    #cursor-bubble.is-image #cursor-ring circle {
      stroke: rgba(0, 0, 0, 0.6);
    }

    @keyframes ring-spin {
      to { transform: rotate(360deg); }
    }

    :global(body) {
      cursor: none;
    }

    :global(a),
    :global(button),
    :global([role="button"]),
    :global([data-zoomable]),
    :global(#lightbox) {
      cursor: none;
    }
  }
</style>
